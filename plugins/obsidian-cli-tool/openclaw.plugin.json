{
  "id": "obsidian-cli-tool",
  "name": "Obsidian CLI Tool",
  "description": "First-class Obsidian vault tools backed by obsidian-cli.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "command": { "type": "string" },
